# PostgreSQL connection (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erp?schema=public"

# JWT (required — change JWT_SECRET in production)
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# CORS — frontend origin(s), comma-separated for multiple
CORS_ORIGIN="http://localhost:5173"

# Public base URL for mobile APK download links (use LAN IP for device testing)
APP_PUBLIC_URL="http://localhost:3000"

# Field Android app version (GET /api/app/field-android/latest)
FIELD_ANDROID_VERSION_CODE=1
FIELD_ANDROID_VERSION_NAME="1.0.0"
FIELD_ANDROID_MIN_VERSION_CODE=1
FIELD_ANDROID_FORCE_UPDATE=false
FIELD_ANDROID_RELEASE_NOTES="初始版本"
# Relative path served from backend/public/apk, or absolute HTTPS URL
FIELD_ANDROID_APK_PATH="/apk/erp-field-latest.apk"

# Field iOS app version (GET /api/app/field-ios/latest)
FIELD_IOS_VERSION_CODE=1
FIELD_IOS_VERSION_NAME="1.0.0"
FIELD_IOS_MIN_VERSION_CODE=1
FIELD_IOS_FORCE_UPDATE=false
FIELD_IOS_RELEASE_NOTES="iOS 外勤初始版"
# TestFlight public link or App Store URL (must be https)
FIELD_IOS_DOWNLOAD_URL="https://testflight.apple.com/join/YOUR_CODE"

# Set to "true" on first deploy to run seed after migrate (Docker entrypoint)
RUN_SEED=false

# Seed demo account passwords (change before any shared/production deploy)
SEED_ADMIN_PASSWORD="change-me-admin"
SEED_DEMO_PASSWORD="change-me-demo"

# Redis (optional — enables distributed cache for reports/dashboard)
# REDIS_URL="redis://localhost:6379"

# MinIO / S3-compatible storage (optional — required for lead call recordings)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=erp-files
MINIO_USE_SSL=false

# Blockchain RPC (optional — anchors batch hashes on a public chain when configured)
# BLOCKCHAIN_RPC_URL="https://sepolia.infura.io/v3/your-key"
# BLOCKCHAIN_PRIVATE_KEY="0x..."
# BLOCKCHAIN_NETWORK_NAME="sepolia"

# 高德 Web 服务 Key（沈阳 POI 公海全量导入，见 scripts/import-shenyang-poi.mjs）
# AMAP_API_KEY="your-amap-web-service-key"
