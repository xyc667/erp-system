{
  "name": "erp-system",
  "version": "1.0.0",
  "description": "Enterprise Resource Planning System",
  "scripts": {
    "start:backend": "cd backend && npm run start:dev",
    "start:frontend": "cd frontend && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test": "npm run test:backend && npm run test:frontend",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:install": "playwright install chromium",
    "init:db": "node -e \"require('child_process').execSync(process.platform==='win32'?'powershell -File scripts/init-db.ps1':'bash scripts/init-db.sh',{stdio:'inherit'})\"",
    "verify:migrations": "node -e \"require('child_process').execSync(process.platform==='win32'?'powershell -File scripts/verify-migrations.ps1':'bash scripts/verify-migrations.sh',{stdio:'inherit'})\"",
    "test:perf": "node tests/perf/load-smoke.mjs",
    "test:perf:full": "node tests/perf/load-smoke.mjs --full",
    "test:perf:k6": "k6 run tests/perf/k6-ci.js",
    "test:perf:k6:load": "k6 run tests/perf/k6-load.js",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml --env-file docker/.env.prod up -d --build",
    "k8s:apply": "kubectl apply -k k8s/",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ../mobile-field && npm install",
    "start:mobile-field": "cd mobile-field && npm run android",
    "docs:pdf": "node scripts/export-manual-pdf.mjs",
    "docs:pdf:field-app": "node scripts/export-manual-pdf.mjs FIELD_APP",
    "docs:screenshots:leads": "node scripts/capture-leads-manual-screenshots.mjs",
    "docs:screenshots:finance": "node scripts/capture-finance-manual-screenshots.mjs",
    "docs:screenshots:procurement": "node scripts/capture-procurement-manual-screenshots.mjs",
    "docs:screenshots:production": "node scripts/capture-production-manual-screenshots.mjs",
    "docs:screenshots:inventory": "node scripts/capture-inventory-manual-screenshots.mjs",
    "docs:screenshots:hr": "node scripts/capture-hr-manual-screenshots.mjs",
    "docs:screenshots:project": "node scripts/capture-project-manual-screenshots.mjs",
    "docs:screenshots:report": "node scripts/capture-report-manual-screenshots.mjs",
    "docs:screenshots:intelligence": "node scripts/capture-intelligence-manual-screenshots.mjs",
    "docs:screenshots:system": "node scripts/capture-system-manual-screenshots.mjs",
    "docs:screenshots": "npm run docs:screenshots:leads && npm run docs:screenshots:procurement && npm run docs:screenshots:finance && npm run docs:screenshots:production && npm run docs:screenshots:inventory && npm run docs:screenshots:hr && npm run docs:screenshots:project && npm run docs:screenshots:report && npm run docs:screenshots:intelligence && npm run docs:screenshots:system",
    "docs:verify:hr": "node scripts/test-hr-flow.mjs",
    "docs:verify:project": "node scripts/test-project-flow.mjs",
    "docs:verify:report": "node scripts/test-report-flow.mjs",
    "docs:verify:intelligence": "node scripts/test-intelligence-flow.mjs",
    "docs:verify:system": "node scripts/test-system-flow.mjs",
    "docs:verify:field-version": "node scripts/test-field-version.mjs",
    "build:field-apk": "cd mobile-field && npm run build:apk",
    "docs:verify:flows": "node scripts/verify-manual-flows.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "marked": "^18.0.5"
  }
}
