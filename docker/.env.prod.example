# 云服务器生产环境 — 复制为 docker/.env.prod 后修改，勿提交 Git
# 使用: docker compose -f docker/docker-compose.prod.yml --env-file docker/.env.prod up -d --build

# ---------- 对外访问（必改）----------
APP_PUBLIC_URL=https://erp.example.com
CORS_ORIGIN=https://erp.example.com

# ---------- 密钥（必改）----------
JWT_SECRET=change-me-to-a-long-random-string
POSTGRES_PASSWORD=change-me-postgres
MINIO_ROOT_USER=change-me-minio
MINIO_ROOT_PASSWORD=change-me-minio-secret

# ---------- 首次部署 ----------
# 首次 true 写入种子数据，成功后改为 false
RUN_SEED=true
SEED_ADMIN_PASSWORD=change-me-admin
SEED_DEMO_PASSWORD=change-me-demo

# ---------- 外勤 Android 版本（发版时递增）----------
FIELD_ANDROID_VERSION_CODE=4
FIELD_ANDROID_VERSION_NAME=1.1.0
FIELD_ANDROID_MIN_VERSION_CODE=1
FIELD_ANDROID_FORCE_UPDATE=false
FIELD_ANDROID_RELEASE_NOTES=云环境初始发布
FIELD_ANDROID_APK_PATH=/apk/erp-field-latest.apk

# ---------- 外勤 iOS（TestFlight）----------
FIELD_IOS_VERSION_CODE=1
FIELD_IOS_VERSION_NAME=1.0.0
FIELD_IOS_MIN_VERSION_CODE=1
FIELD_IOS_FORCE_UPDATE=false
FIELD_IOS_RELEASE_NOTES=iOS 云环境初始发布
FIELD_IOS_DOWNLOAD_URL=https://testflight.apple.com/join/YOUR_CODE

# ---------- 可选：区块链锚定等见 backend/.env.example ----------
